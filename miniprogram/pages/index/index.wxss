page {
  min-height: 100vh;
  background: #090912;
  color: #f7f1ff;
}

button {
  min-height: 78rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 28rpx;
  background: transparent;
  color: inherit;
  font-weight: 800;
  font-size: 28rpx;
  line-height: 78rpx;
}

button::after {
  border: 0;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 8% 4%, rgba(255, 143, 199, 0.24), transparent 34%),
    radial-gradient(circle at 92% 88%, rgba(125, 211, 252, 0.16), transparent 38%),
    linear-gradient(135deg, #090912 0%, #121225 50%, #090912 100%);
}

.noise {
  position: fixed;
  inset: 0;
  opacity: 0.12;
  pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,.28) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
}

.floating-star {
  position: fixed;
  z-index: 0;
  color: #ffd166;
  opacity: 0.72;
  font-size: 42rpx;
}

.star-one {
  top: 170rpx;
  right: 80rpx;
}

.star-two {
  left: 62rpx;
  bottom: 180rpx;
  color: #ff8fc7;
}

.entrance-screen {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: calc(100vh - 56rpx);
  align-items: center;
  justify-content: center;
}

.entrance-card,
.flow-panel,
.landing-card,
.mode-zone,
.picker-card,
.turn-selector,
.draw-selector,
.little-note,
.history-section,
.secret-letter,
.site-dialog-card {
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.36);
  backdrop-filter: blur(18px);
}

.entrance-card {
  width: 100%;
  padding: 54rpx 40rpx;
  border-radius: 44rpx;
  text-align: center;
}

.step-label,
.eyebrow {
  color: #9ec8ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 5rpx;
  text-transform: uppercase;
}

.entrance-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
}

.entrance-copy,
.intro-copy,
.setup-note,
.zone-sub,
.landing-sub,
.deck-description,
.deck-preview-subtitle,
.history-sub,
.history-empty,
.plan-entry-sub,
.plan-notes-sub {
  color: #b9aecb;
  font-size: 26rpx;
  line-height: 1.6;
}

.entrance-input,
.site-dialog-input,
.option-input,
.letter-input,
.plan-note-input {
  width: 100%;
  margin-top: 26rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 26rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.08);
  color: #f7f1ff;
  font-size: 28rpx;
}

.start-game-button,
.pick-button,
.special-password-button {
  width: 100%;
  margin-top: 28rpx;
  min-height: 92rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ff8fc7, #a78bfa);
  color: #fff;
  box-shadow: 0 0 34rpx rgba(255, 143, 199, 0.3);
}

.entrance-error {
  margin-top: 18rpx;
  color: #ffb4c0;
  font-size: 24rpx;
}

.app-content,
.screen {
  position: relative;
  z-index: 1;
}

.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-mark {
  width: 58rpx;
  height: 58rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ff8fc7, #a78bfa);
  color: #fff;
  text-align: center;
  font-weight: 900;
  line-height: 58rpx;
}

.brand-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.header-note {
  flex: 1;
  color: #b9aecb;
  font-size: 22rpx;
  text-align: right;
  line-height: 1.35;
}

.intro {
  padding-top: 28rpx;
}

.intro-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.1;
}

.intro-title text {
  color: #ff8fc7;
}

.intro-copy {
  margin-top: 22rpx;
}

.doodle-arrow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 20rpx;
  color: #ffd166;
  font-size: 24rpx;
}

.arrow-line {
  font-size: 56rpx;
}

.landing-card {
  padding: 32rpx;
  border-radius: 36rpx;
}

.landing-label {
  color: #ffb4d6;
  font-size: 24rpx;
  font-weight: 900;
}

.landing-main {
  margin-top: 14rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.landing-sub {
  margin-top: 16rpx;
}

.footer-copy {
  margin-top: 30rpx;
  color: rgba(247, 241, 255, 0.44);
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-align: center;
}

.flow-panel {
  padding: 24rpx;
  border-radius: 38rpx;
}

.panel-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ghost-back-button,
.secondary-button,
.text-button,
.add-button {
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  color: #f7f1ff;
}

.ghost-back-button {
  min-height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.flow-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(158, 200, 255, 0.14);
  color: #9ec8ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.setup-copy {
  margin: 30rpx 0 22rpx;
}

.flow-title,
.section-title,
.zone-title,
.deck-title,
.result-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.mode-zone {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 34rpx;
}

.special-zone {
  background: linear-gradient(145deg, rgba(255, 143, 199, 0.14), rgba(167, 139, 250, 0.12));
}

.classic-zone {
  background: rgba(255, 255, 255, 0.07);
}

.special-entry-button {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.08);
  line-height: 1.3;
  text-align: left;
}

.special-entry-mark {
  width: 66rpx;
  height: 66rpx;
  margin-right: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 143, 199, 0.22);
  color: #ffb4d6;
  line-height: 66rpx;
  text-align: center;
}

.special-entry-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.entry-strong,
.mode-name,
.deck-preview-title,
.plan-entry-title,
.plan-notes-label {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.entry-small,
.mode-desc {
  margin-top: 6rpx;
  color: #b9aecb;
  font-size: 23rpx;
}

.special-entry-arrow {
  color: #ffd166;
  font-size: 34rpx;
}

.mode-buttons {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.classic-buttons {
  grid-template-columns: repeat(3, 1fr);
}

.mode-button {
  display: flex;
  flex-direction: column;
  min-height: 184rpx;
  padding: 20rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.08);
  text-align: center;
  line-height: 1.25;
}

.mode-mark {
  align-self: center;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 143, 199, 0.18);
  color: #ffd6ea;
  font-weight: 900;
  line-height: 52rpx;
}

.full-row {
  min-height: 156rpx;
}

.turn-selector,
.draw-selector {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 32rpx;
}

.player-switch,
.draw-switch,
.draw-actions,
.letter-actions,
.site-dialog-actions,
.plan-note-form {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.player-switch button,
.draw-switch button {
  flex: 1;
  min-height: 68rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b9aecb;
  font-size: 24rpx;
  line-height: 68rpx;
}

.player-switch .active,
.draw-switch .active {
  background: linear-gradient(135deg, rgba(255, 143, 199, 0.95), rgba(167, 139, 250, 0.95));
  color: #fff;
}

.picker-card {
  margin-top: 18rpx;
  border-radius: 38rpx;
  overflow: hidden;
}

.options-panel,
.result-panel {
  padding: 24rpx;
}

.result-panel {
  background: rgba(13, 21, 46, 0.82);
}

.panel-heading,
.result-toolbar,
.history-heading,
.plan-notes-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.option-count {
  color: #ffb4d6;
  font-size: 24rpx;
}

.deck-description {
  margin-top: 12rpx;
}

.option-input {
  min-height: 148rpx;
}

.template-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.template-buttons button {
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b9aecb;
  font-size: 22rpx;
  line-height: 54rpx;
}

.add-button {
  width: 100%;
  margin-top: 14rpx;
}

.danger {
  margin-top: 14rpx;
  color: #ffb4c0;
  border-color: rgba(255, 107, 129, 0.35);
  background: rgba(255, 107, 129, 0.08);
}

.result-toolbar {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.result-toolbar .secondary-button {
  width: 190rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  font-size: 24rpx;
}

.sparkle {
  color: #ffd166;
  font-size: 42rpx;
}

.result-stage {
  position: relative;
  min-height: 430rpx;
  margin: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.orbit {
  position: absolute;
  width: 420rpx;
  height: 260rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.16);
  border-radius: 50%;
}

.orbit-one {
  transform: rotate(18deg);
}

.orbit-two {
  transform: rotate(-14deg);
}

.result-ticket {
  position: relative;
  z-index: 1;
  width: 88%;
  min-height: 300rpx;
  padding: 32rpx 26rpx;
  border: 3rpx solid rgba(158, 200, 255, 0.34);
  border-radius: 28rpx;
  background: #f8f2e8;
  color: #27334c;
  box-shadow: 14rpx 18rpx 0 rgba(0, 0, 0, 0.22);
  text-align: center;
  transform: rotate(-2deg);
}

.ticket-recipient,
.result-type-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #ffd9eb;
  color: #9b3b68;
  font-size: 22rpx;
  font-weight: 900;
}

.result-type-tag {
  margin-left: 10rpx;
  background: #ece5fb;
  color: #6d55a8;
}

.result-kicker {
  margin-top: 34rpx;
  color: #516078;
  font-size: 28rpx;
  font-weight: 900;
}

.result-text {
  margin-top: 18rpx;
  color: #ff5f7f;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.28;
  word-break: break-word;
}

.result-caption {
  margin-top: 22rpx;
  color: #516078;
  font-size: 24rpx;
  font-weight: 800;
}

.pick-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 0 34rpx;
}

.button-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 24rpx;
  background: rgba(9, 9, 18, 0.36);
  line-height: 66rpx;
  text-align: center;
}

.draw-actions .secondary-button,
.letter-actions .secondary-button,
.letter-actions .special-password-button,
.site-dialog-actions .secondary-button,
.site-dialog-actions .special-password-button {
  flex: 1;
  margin-top: 0;
}

.settings {
  margin-top: 18rpx;
}

.reset-round-button {
  width: 100%;
}

.no-repeat-note {
  margin-top: 14rpx;
  color: #b9aecb;
  font-size: 24rpx;
}

.little-note,
.history-section {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 34rpx;
}

.quote {
  margin-top: 12rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.6;
}

.note-sign {
  display: block;
  margin-top: 14rpx;
  color: #ffb4d6;
  font-size: 24rpx;
  text-align: right;
}

.history-item,
.plan-note-item {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.07);
}

.history-main,
.plan-note-text {
  color: #fff;
  font-size: 27rpx;
  line-height: 1.55;
}

.history-sub,
.plan-note-time {
  display: block;
  margin-top: 8rpx;
}

.letter-prompt {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  color: #b9aecb;
  font-size: 24rpx;
}

.letter-prompt .secondary-button {
  min-width: 188rpx;
  min-height: 62rpx;
  line-height: 62rpx;
  font-size: 24rpx;
}

.letter-shell,
.plan-shell {
  margin-top: 26rpx;
}

.secret-letter {
  margin-top: 20rpx;
  padding: 26rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.09);
}

.letter-stamp {
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 143, 199, 0.2);
  color: #ffd6ea;
  font-weight: 900;
  font-size: 22rpx;
}

.letter-input {
  min-height: 520rpx;
  line-height: 1.6;
}

.letter-hidden {
  color: transparent;
  text-shadow: 0 0 18rpx rgba(247, 241, 255, 0.72);
}

.letter-count {
  flex: 0.8;
  color: #b9aecb;
  font-size: 23rpx;
  line-height: 78rpx;
}

.plan-document-entry-button {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255, 143, 199, 0.14), rgba(167, 139, 250, 0.12));
}

.plan-document-view {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #f8f2e8;
  color: #27334c;
}

.plan-document-title {
  text-align: center;
  color: #1e2840;
  font-size: 34rpx;
  font-weight: 900;
}

.plan-document-text {
  margin-top: 18rpx;
  white-space: pre-wrap;
  font-size: 27rpx;
  line-height: 1.7;
}

.plan-input {
  min-height: 600rpx;
}

.plan-notes-block {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.plan-notes-head {
  align-items: flex-start;
  flex-direction: column;
}

.plan-note-input {
  flex: 1;
  min-height: 78rpx;
  margin-top: 0;
}

.plan-note-form .secondary-button {
  width: 150rpx;
}

.plan-note-pin-button {
  margin-top: 12rpx;
  min-height: 56rpx;
  line-height: 56rpx;
  color: #ffb4d6;
  background: rgba(255, 143, 199, 0.12);
}

.toast {
  position: fixed;
  left: 50%;
  bottom: 70rpx;
  z-index: 30;
  transform: translateX(-50%);
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(20, 20, 38, 0.94);
  color: #fff;
  font-size: 26rpx;
  box-shadow: 0 14rpx 42rpx rgba(0, 0, 0, 0.34);
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx;
  background: rgba(0, 0, 0, 0.62);
}

.site-dialog-card {
  width: 100%;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #151528;
}

.dialog-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.dialog-message {
  margin-top: 12rpx;
  color: #b9aecb;
  font-size: 26rpx;
}
