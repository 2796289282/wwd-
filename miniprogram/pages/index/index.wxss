page {
  min-height: 100vh;
  background: #090912;
  color: #f7f1ff;
}

button {
  min-height: 78rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 28rpx;
  background: transparent;
  color: inherit;
  font-weight: 800;
  font-size: 28rpx;
  line-height: 78rpx;
}

button::after {
  border: 0;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 8% 4%, rgba(255, 143, 199, 0.24), transparent 34%),
    radial-gradient(circle at 92% 88%, rgba(125, 211, 252, 0.16), transparent 38%),
    linear-gradient(135deg, #090912 0%, #121225 50%, #090912 100%);
}

.noise {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0.12;
  pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,.28) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
}

.floating-star {
  position: fixed;
  z-index: 0;
  color: #ffd166;
  opacity: 0.72;
  font-size: 42rpx;
}

.star-one {
  top: 170rpx;
  right: 80rpx;
}

.star-two {
  left: 62rpx;
  bottom: 180rpx;
  color: #ff8fc7;
}

.entrance-screen {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: calc(100vh - 56rpx);
  align-items: center;
  justify-content: center;
}

.entrance-card,
.flow-panel,
.landing-card,
.mode-zone,
.picker-card,
.turn-selector,
.draw-selector,
.little-note,
.history-section,
.secret-letter,
.site-dialog-card {
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.36);
  backdrop-filter: blur(18px);
}

.entrance-card {
  width: 100%;
  padding: 54rpx 40rpx;
  border-radius: 44rpx;
  text-align: center;
}

.step-label,
.eyebrow {
  color: #9ec8ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 5rpx;
  text-transform: uppercase;
}

.entrance-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
}

.entrance-copy,
.intro-copy,
.setup-note,
.zone-sub,
.landing-sub,
.deck-description,
.deck-preview-subtitle,
.history-sub,
.history-empty,
.plan-entry-sub,
.plan-notes-sub {
  color: #b9aecb;
  font-size: 26rpx;
  line-height: 1.6;
}

.entrance-input,
.site-dialog-input,
.option-input,
.letter-input,
.plan-note-input {
  width: 100%;
  margin-top: 26rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 26rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.08);
  color: #f7f1ff;
  font-size: 28rpx;
}

.entrance-input,
.site-dialog-input,
.plan-note-input {
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 26rpx;
  line-height: 88rpx;
}

.start-game-button,
.pick-button,
.special-password-button {
  width: 100%;
  margin-top: 28rpx;
  min-height: 92rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ff8fc7, #a78bfa);
  color: #fff;
  box-shadow: 0 0 34rpx rgba(255, 143, 199, 0.3);
}

.entrance-error {
  margin-top: 18rpx;
  color: #ffb4c0;
  font-size: 24rpx;
}

.app-content,
.screen {
  position: relative;
  z-index: 1;
}

.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-mark {
  width: 58rpx;
  height: 58rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ff8fc7, #a78bfa);
  color: #fff;
  text-align: center;
  font-weight: 900;
  line-height: 58rpx;
}

.brand-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.header-note {
  flex: 1;
  color: #b9aecb;
  font-size: 22rpx;
  text-align: right;
  line-height: 1.35;
}

.intro-letter-button {
  position: absolute;
  top: 204rpx;
  right: 12rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 42rpx;
  min-height: 42rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 143, 199, 0.28);
  border-radius: 999rpx;
  background: rgba(255, 143, 199, 0.14);
  color: #ffd6ea;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 0 18rpx rgba(255, 143, 199, 0.14);
}

.intro-letter-button-press {
  transform: scale(0.96);
  opacity: 0.9;
}

.intro {
  padding-top: 28rpx;
}

.intro-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.1;
}

.intro-title text {
  color: #ff8fc7;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #7dd3fc;
}

.hero-eyebrow text {
  width: 62rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ff8fc7;
  transform: rotate(-3deg);
}

.hero-title {
  display: flex;
  flex-direction: column;
  margin-top: 26rpx;
  letter-spacing: -2rpx;
}

.hero-title-main,
.hero-title-accent {
  display: block;
}

.intro-title .hero-title-main {
  color: #f7f1ff;
  font-size: 86rpx;
  line-height: 0.98;
}

.intro-title .hero-title-accent {
  margin-top: 6rpx;
  color: #7dd3fc;
  font-size: 76rpx;
  line-height: 1.02;
}

.hero-underline {
  width: 100%;
  height: 8rpx;
  margin: 24rpx 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8fc7, #ff6b4a);
  transform: rotate(-1deg);
}

.intro-copy {
  margin-top: 22rpx;
}

.doodle-arrow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 20rpx;
  color: #ffd166;
  font-size: 24rpx;
}

.arrow-line {
  font-size: 56rpx;
}

.landing-card {
  padding: 32rpx;
  border-radius: 36rpx;
}

.landing-label {
  color: #ffb4d6;
  font-size: 24rpx;
  font-weight: 900;
}

.landing-main {
  margin-top: 14rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.landing-sub {
  margin-top: 16rpx;
}

.footer-copy {
  margin-top: 30rpx;
  color: rgba(247, 241, 255, 0.44);
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-align: center;
}

.flow-panel {
  padding: 24rpx;
  border-radius: 38rpx;
}

.panel-topline {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
}

.secondary-button,
.text-button,
.add-button {
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  color: #f7f1ff;
}

.ghost-back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0;
  margin-right: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  color: #f7f1ff;
  min-height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.flow-badge {
  margin-left: auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(158, 200, 255, 0.14);
  color: #9ec8ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.setup-copy {
  margin: 30rpx 0 22rpx;
}

.flow-title,
.section-title,
.zone-title,
.deck-title,
.result-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.mode-zone {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 34rpx;
}

.special-zone {
  background: linear-gradient(145deg, rgba(255, 143, 199, 0.14), rgba(167, 139, 250, 0.12));
}

.classic-zone {
  background: rgba(255, 255, 255, 0.07);
}

.special-entry-button {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
  min-height: 108rpx;
  margin-top: 18rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.1);
  line-height: 1.3;
  text-align: left;
}

.special-entry-mark {
  width: 66rpx;
  height: 66rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #ffb4d6;
  line-height: 66rpx;
  text-align: center;
  font-size: 34rpx;
}

.special-entry-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.entry-strong,
.mode-name,
.deck-preview-title,
.plan-entry-title,
.plan-notes-label {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.entry-small,
.mode-desc {
  margin-top: 6rpx;
  color: #b9aecb;
  font-size: 23rpx;
}

.special-entry-arrow {
  color: #ff8fc7;
  font-size: 44rpx;
}

.mode-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.classic-buttons {
  flex-direction: row;
}

.mode-button {
  display: flex;
  flex-direction: column;
  min-height: 184rpx;
  padding: 20rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.08);
  text-align: center;
  line-height: 1.25;
}

.mode-mark {
  align-self: center;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 143, 199, 0.18);
  color: #ffd6ea;
  font-weight: 900;
  line-height: 52rpx;
}

.full-row {
  min-height: 156rpx;
}

.turn-selector,
.draw-selector {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 32rpx;
}

.player-switch,
.draw-switch,
.draw-actions,
.letter-actions,
.site-dialog-actions,
.plan-note-form {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.player-switch button,
.draw-switch button {
  flex: 1;
  min-height: 68rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b9aecb;
  font-size: 24rpx;
  line-height: 68rpx;
}

.player-switch .active,
.draw-switch .active {
  background: linear-gradient(135deg, rgba(255, 143, 199, 0.95), rgba(167, 139, 250, 0.95));
  color: #fff;
}

.picker-card {
  margin-top: 18rpx;
  border-radius: 38rpx;
  overflow: visible;
}

.options-panel,
.result-panel {
  padding: 24rpx;
}

.result-panel {
  background: rgba(13, 21, 46, 0.82);
}

.panel-heading,
.result-toolbar,
.history-heading,
.plan-notes-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.option-count {
  color: #ffb4d6;
  font-size: 24rpx;
}

.deck-description {
  margin-top: 12rpx;
}

.option-input {
  min-height: 148rpx;
}

.template-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.template-buttons button {
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b9aecb;
  font-size: 22rpx;
  line-height: 54rpx;
}

.add-button {
  width: 100%;
  margin-top: 14rpx;
}

.danger {
  margin-top: 14rpx;
  color: #ffb4c0;
  border-color: rgba(255, 107, 129, 0.35);
  background: rgba(255, 107, 129, 0.08);
}

.result-toolbar {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.result-toolbar .secondary-button {
  width: 190rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  font-size: 24rpx;
}

.remaining-bank {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.07);
}

.remaining-bank-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
}

.remaining-bank-head text:last-child {
  color: #ffb4d6;
  font-size: 22rpx;
}

.remaining-bank-list {
  height: 230rpx;
  margin-top: 12rpx;
}

.remaining-card-item {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.remaining-card-index {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(255, 143, 199, 0.14);
  color: #ffb4d6;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.remaining-card-text {
  flex: 1;
  color: #dcd4e8;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-word;
}

.remaining-empty {
  padding: 18rpx 0;
  color: #b9aecb;
  font-size: 24rpx;
  line-height: 1.5;
}

.sparkle {
  color: #ffd166;
  font-size: 42rpx;
}

.result-stage {
  position: relative;
  min-height: 430rpx;
  margin: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.orbit {
  position: absolute;
  width: 420rpx;
  height: 260rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.16);
  border-radius: 50%;
}

.orbit-one {
  transform: rotate(18deg);
}

.orbit-two {
  transform: rotate(-14deg);
}

.result-ticket {
  position: relative;
  z-index: 1;
  width: 88%;
  min-height: 300rpx;
  padding: 32rpx 26rpx;
  border: 3rpx solid rgba(158, 200, 255, 0.34);
  border-radius: 28rpx;
  background: #f8f2e8;
  color: #27334c;
  box-shadow: 14rpx 18rpx 0 rgba(0, 0, 0, 0.22);
  text-align: center;
  transform: rotate(-2deg);
}

.ticket-recipient,
.result-type-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #ffd9eb;
  color: #9b3b68;
  font-size: 22rpx;
  font-weight: 900;
}

.result-type-tag {
  margin-left: 10rpx;
  background: #ece5fb;
  color: #6d55a8;
}

.result-kicker {
  margin-top: 34rpx;
  color: #516078;
  font-size: 28rpx;
  font-weight: 900;
}

.result-text {
  margin-top: 18rpx;
  color: #ff5f7f;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.28;
  word-break: break-word;
}

.result-caption {
  margin-top: 22rpx;
  color: #516078;
  font-size: 24rpx;
  font-weight: 800;
}

.pick-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 0 34rpx;
}

.button-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 24rpx;
  background: rgba(9, 9, 18, 0.36);
  line-height: 66rpx;
  text-align: center;
}

.draw-actions .secondary-button,
.letter-actions .secondary-button,
.letter-actions .special-password-button,
.site-dialog-actions .secondary-button,
.site-dialog-actions .special-password-button {
  flex: 1;
  margin-top: 0;
}

.settings {
  margin-top: 18rpx;
}

.reset-round-button {
  width: 100%;
}

.no-repeat-note {
  margin-top: 14rpx;
  color: #b9aecb;
  font-size: 24rpx;
}

.little-note,
.history-section {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 34rpx;
}

.quote {
  margin-top: 12rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.6;
}

.note-sign {
  display: block;
  margin-top: 14rpx;
  color: #ffb4d6;
  font-size: 24rpx;
  text-align: right;
}

.history-item,
.plan-note-item {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.07);
}

.history-main,
.plan-note-text {
  color: #fff;
  font-size: 27rpx;
  line-height: 1.55;
}

.history-sub,
.plan-note-time {
  display: block;
  margin-top: 8rpx;
}

.letter-prompt {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  color: #b9aecb;
  font-size: 24rpx;
}

.letter-prompt .secondary-button {
  min-width: 188rpx;
  min-height: 62rpx;
  line-height: 62rpx;
  font-size: 24rpx;
}

.letter-shell,
.plan-shell {
  margin-top: 26rpx;
}

.secret-letter {
  margin-top: 20rpx;
  padding: 26rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.09);
}

.letter-stamp {
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 143, 199, 0.2);
  color: #ffd6ea;
  font-weight: 900;
  font-size: 22rpx;
}

.letter-input {
  min-height: 520rpx;
  line-height: 1.6;
}

.letter-hidden {
  color: transparent;
  text-shadow: 0 0 18rpx rgba(247, 241, 255, 0.72);
}

.letter-count {
  flex: 0.8;
  color: #b9aecb;
  font-size: 23rpx;
  line-height: 78rpx;
}

.plan-document-entry-button {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255, 143, 199, 0.14), rgba(167, 139, 250, 0.12));
}

.plan-document-view {
  margin-top: 18rpx;
  padding: 28rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 143, 199, 0.12), transparent 34%),
    rgba(255, 255, 255, 0.07);
  color: #f7f1ff;
}

.plan-document-title {
  text-align: center;
  color: #1e2840;
  font-size: 34rpx;
  font-weight: 900;
}

.plan-document-text {
  margin-top: 18rpx;
  white-space: pre-wrap;
  font-size: 27rpx;
  line-height: 1.7;
}

.plan-doc-p {
  color: #e8def4;
  font-size: 27rpx;
  line-height: 1.75;
  word-break: break-word;
}

.plan-doc-title {
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
}

.plan-doc-subtitle {
  margin-top: 8rpx;
  color: #ffb4d6;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 2rpx;
}

.plan-doc-h1 {
  margin-top: 34rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #9ec8ff;
  font-size: 33rpx;
  font-weight: 900;
}

.plan-doc-h2 {
  margin-top: 24rpx;
  color: #ffd6ea;
  font-size: 29rpx;
  font-weight: 900;
}

.plan-doc-body {
  margin-top: 14rpx;
}

.plan-doc-check {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #f7f1ff;
}

.plan-doc-quote,
.plan-doc-callout {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 143, 199, 0.2);
  border-radius: 24rpx;
  background: rgba(255, 143, 199, 0.1);
  color: #ffd6ea;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.65;
}

.plan-doc-table-scroll {
  width: 100%;
  margin-top: 18rpx;
}

.plan-doc-table {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 22rpx;
}

.plan-doc-row {
  display: flex;
  min-height: 66rpx;
}

.plan-doc-cell {
  flex-shrink: 0;
  padding: 16rpx 14rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.12);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.055);
  color: #efe8f8;
  font-size: 23rpx;
  line-height: 1.55;
  word-break: break-word;
}

.plan-doc-cell.is-head {
  background: rgba(255, 143, 199, 0.17);
  color: #fff;
  font-weight: 900;
}

.plan-input {
  min-height: 600rpx;
}

.plan-notes-block {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.plan-notes-head {
  align-items: flex-start;
  flex-direction: column;
}

.plan-note-input {
  flex: 1;
  min-height: 78rpx;
  margin-top: 0;
}

.plan-note-form .secondary-button {
  width: 150rpx;
}

.plan-note-pin-button {
  margin-top: 12rpx;
  min-height: 56rpx;
  line-height: 56rpx;
  color: #ffb4d6;
  background: rgba(255, 143, 199, 0.12);
}

.plan-note-edit-input {
  width: 100%;
  min-height: 88rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(255, 143, 199, 0.24);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 27rpx;
  line-height: 1.5;
}

.toast {
  position: fixed;
  left: 50%;
  bottom: 70rpx;
  z-index: 30;
  transform: translateX(-50%);
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(20, 20, 38, 0.94);
  color: #fff;
  font-size: 26rpx;
  box-shadow: 0 14rpx 42rpx rgba(0, 0, 0, 0.34);
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx;
  background: rgba(0, 0, 0, 0.62);
}

.site-dialog-card {
  width: 100%;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #151528;
}

.dialog-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.dialog-message {
  margin-top: 12rpx;
  color: #b9aecb;
  font-size: 26rpx;
}

/* Mobile adaptation hardening for WeChat Mini Program real devices. */
page {
  height: 100vh;
  overflow: hidden;
}

view,
text,
input,
textarea,
button,
scroll-view {
  box-sizing: border-box;
}

.page {
  height: 100vh;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  width: 100%;
}

.app-content,
.entrance-screen {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(42rpx + constant(safe-area-inset-bottom));
  padding: 28rpx 28rpx calc(42rpx + env(safe-area-inset-bottom));
}

.entrance-screen {
  display: flex;
  align-items: center;
  justify-content: center;
}

.entrance-card {
  max-width: 686rpx;
  padding: 46rpx 34rpx;
}

.entrance-title {
  font-size: 52rpx;
  line-height: 1.18;
  word-break: break-word;
}

.screen {
  width: 100%;
  min-width: 0;
}

.screen-animate {
  animation: pageFadeUp 220ms ease-out both;
}

.card-animate,
.modal-mask .site-dialog-card {
  animation: softPop 180ms ease-out both;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  min-width: 0;
  line-height: 1.22;
  transition: transform 120ms ease, opacity 120ms ease, background-color 160ms ease;
}

button:active,
.mode-button:active,
.plan-document-entry-button:active {
  transform: scale(0.975);
  opacity: 0.9;
}

.tap-press {
  transform: scale(0.975);
  opacity: 0.9;
}

input,
textarea {
  max-width: 100%;
}

.entrance-input,
.site-dialog-input,
.option-input,
.letter-input,
.plan-note-input {
  min-width: 0;
}

.noise,
.floating-star {
  pointer-events: none;
}

.floating-star {
  max-width: 80rpx;
  overflow: hidden;
}

.star-one {
  top: 110rpx;
  right: 34rpx;
}

.star-two {
  left: 32rpx;
  bottom: calc(96rpx + constant(safe-area-inset-bottom));
  bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.site-header {
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 14rpx;
  padding-top: 2rpx;
}

.brand {
  min-width: 0;
  max-width: 100%;
}

.brand-text {
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-note {
  min-width: 0;
  flex: 1 1 180rpx;
  word-break: break-word;
}

.intro-title {
  font-size: 58rpx;
  word-break: break-word;
}

.intro-title .hero-title-main {
  font-size: 84rpx;
}

.intro-title .hero-title-accent {
  font-size: 74rpx;
}

.flow-panel {
  width: 100%;
  padding: 22rpx;
  overflow: visible;
}

.panel-topline,
.panel-heading,
.result-toolbar,
.history-heading {
  align-items: flex-start;
}

.ghost-back-button {
  flex-shrink: 0;
  align-self: flex-start;
  width: 190rpx;
  max-width: 190rpx;
  min-height: 78rpx;
  padding: 0;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.panel-topline {
  justify-content: flex-start;
}

.panel-topline .ghost-back-button {
  margin-left: 0;
}

.panel-topline .flow-badge {
  margin-left: auto;
}

.special-entry-button {
  width: 100%;
  min-height: 104rpx;
  padding: 12rpx 18rpx;
}

.flow-badge {
  flex-shrink: 0;
  white-space: nowrap;
}

.flow-title,
.section-title,
.zone-title,
.deck-title,
.result-title,
.landing-main {
  word-break: break-word;
}

.mode-zone,
.turn-selector,
.draw-selector,
.little-note,
.history-section,
.secret-letter {
  overflow: visible;
}

.classic-buttons {
  display: flex;
  flex-direction: row;
}

.mode-button {
  height: auto;
  min-width: 0;
  min-height: 166rpx;
  padding: 18rpx 10rpx;
  overflow: visible;
}

.classic-buttons .mode-button {
  flex: 1;
}

.special-buttons {
  display: flex;
  flex-direction: column;
}

.special-buttons .mode-button {
  width: 100%;
}

.template-buttons button {
  min-height: 66rpx;
  padding: 8rpx 18rpx;
  line-height: 1.2;
}

.mode-name,
.mode-desc,
.entry-strong,
.entry-small {
  display: block;
  max-width: 100%;
  word-break: break-word;
  white-space: normal;
}

.player-switch,
.draw-switch,
.draw-actions,
.letter-actions,
.site-dialog-actions,
.plan-note-form,
.letter-prompt {
  flex-wrap: wrap;
}

.player-switch button,
.draw-switch button {
  display: flex;
  min-width: 0;
  min-height: 72rpx;
  padding: 10rpx 8rpx;
  line-height: 1.22;
  white-space: normal;
}

.picker-card {
  overflow: visible;
}

.options-panel {
  border-radius: 36rpx 36rpx 0 0;
}

.result-panel {
  border-radius: 34rpx;
}

.result-toolbar {
  flex-wrap: wrap;
}

.deck-preview {
  min-width: 0;
  flex: 1;
}

.result-toolbar .secondary-button {
  flex-shrink: 0;
  width: auto;
  min-width: 180rpx;
}

.result-stage {
  min-height: 360rpx;
  margin: 18rpx 0 20rpx;
  overflow: visible;
}

.orbit {
  width: 82%;
  max-width: 430rpx;
  height: 230rpx;
}

.result-ticket {
  width: 94%;
  min-height: 270rpx;
  padding: 28rpx 22rpx;
  transform: rotate(-1deg);
}

.result-stage.is-drawing .orbit {
  animation: orbitPulse 520ms ease-in-out infinite alternate;
}

.result-ticket.ticket-drawing {
  animation: cardShuffle 680ms ease-in-out both;
}

.result-ticket.ticket-fresh {
  animation: cardReveal 360ms cubic-bezier(.2, .85, .22, 1.15) both;
}

.ticket-recipient,
.result-type-tag {
  max-width: 100%;
  margin: 0 4rpx 8rpx;
  line-height: 1.25;
  word-break: break-word;
}

.result-type-tag {
  margin-left: 4rpx;
}

.result-kicker {
  margin-top: 22rpx;
}

.result-text {
  font-size: 38rpx;
  line-height: 1.34;
  word-break: break-word;
}

.pick-button {
  min-height: 94rpx;
}

.pick-button-loading {
  opacity: 0.86;
}

.pick-button-loading .button-icon {
  animation: buttonArrowSpin 680ms linear infinite;
}

.button-label {
  min-width: 0;
  flex: 1;
  text-align: left;
  word-break: break-word;
}

.button-icon {
  flex-shrink: 0;
}

.draw-actions .secondary-button,
.letter-actions .secondary-button,
.letter-actions .special-password-button,
.site-dialog-actions .secondary-button,
.site-dialog-actions .special-password-button {
  min-width: 220rpx;
}

.letter-prompt text {
  flex: 1;
  min-width: 260rpx;
}

.letter-prompt .secondary-button {
  flex: 1;
  min-width: 220rpx;
}

.letter-input {
  min-height: 430rpx;
  max-height: 68vh;
}

.plan-input {
  min-height: 480rpx;
  max-height: 70vh;
}

.letter-actions .letter-count,
.plan-actions .letter-count {
  flex: 1 0 100%;
  min-height: 42rpx;
  line-height: 42rpx;
}

.plan-document-view {
  max-width: 100%;
  overflow: visible;
}

.plan-document-text,
.history-main,
.plan-note-text,
.quote {
  word-break: break-word;
  overflow-wrap: break-word;
}

.plan-note-form .secondary-button {
  flex-shrink: 0;
  width: 150rpx;
}

.toast {
  bottom: calc(42rpx + constant(safe-area-inset-bottom));
  bottom: calc(42rpx + env(safe-area-inset-bottom));
  max-width: calc(100vw - 64rpx);
  white-space: normal;
  text-align: center;
  line-height: 1.4;
}

.modal-mask {
  padding: 32rpx 32rpx calc(32rpx + constant(safe-area-inset-bottom));
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  overflow: auto;
}

.site-dialog-card {
  width: 100%;
  max-width: 686rpx;
  max-height: 76vh;
  max-height: calc(100vh - 168rpx - constant(safe-area-inset-bottom));
  max-height: calc(100vh - 168rpx - env(safe-area-inset-bottom));
  overflow: auto;
}

.site-dialog-actions button {
  margin-top: 0;
}

@keyframes pageFadeUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes softPop {
  from {
    opacity: 0;
    transform: scale(0.96);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes orbitPulse {
  from {
    opacity: 0.34;
    transform: scale(0.96) rotate(-8deg);
  }
  to {
    opacity: 0.78;
    transform: scale(1.04) rotate(8deg);
  }
}

@keyframes cardShuffle {
  0% {
    opacity: 0.78;
    transform: translateX(-16rpx) rotate(-4deg) scale(0.98);
  }
  45% {
    opacity: 1;
    transform: translateX(18rpx) rotate(3deg) scale(1.02);
  }
  100% {
    opacity: 0.92;
    transform: translateX(0) rotate(-1deg) scale(1);
  }
}

@keyframes cardReveal {
  from {
    opacity: 0.72;
    transform: translateY(18rpx) rotate(-3deg) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) rotate(-1deg) scale(1);
  }
}

@keyframes buttonArrowSpin {
  from {
    transform: rotate(0);
  }
  to {
    transform: rotate(360deg);
  }
}

@media (max-width: 360px) {
  .intro-letter-button {
    top: 192rpx;
    right: 4rpx;
    width: 88rpx;
    height: 40rpx;
    min-height: 40rpx;
    padding: 0;
    font-size: 19rpx;
    line-height: 1;
  }

  .intro-title .hero-title-main {
    font-size: 76rpx;
  }

  .intro-title .hero-title-accent {
    font-size: 66rpx;
  }
}
